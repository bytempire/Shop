TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_CHAT_ID=
# Работа только через Telegram Mini App: заказ уходит в бота (sendData), его нужно переслать в группу
# с сервера — пример: python3 scripts/bot_forward_webapp_orders.py (те же переменные в окружении).

# Куда слать заказ с сайта (обход CORS). На HTTPS лучше тот же домен — относительный путь:
# ORDER_API_URL=/api/order
# Локально (HTTP): см. scripts/order_api_server.py → http://127.0.0.1:8787/
# ORDER_API_URL=http://127.0.0.1:8787/api/order
# Либо полный URL вашего HTTPS-бэкенда:
# ORDER_API_URL=https://api.example.com/order-to-telegram
